{
  "name": "tokenmeter",
  "version": "1.0.0",
  "description": "Glanceable AI CLI token usage dashboard for developers",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "gen-icon": "node scripts/gen-icon.js",
    "gen-banner": "node scripts/gen-banner.js",
    "prebuild": "node scripts/gen-icon.js",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": ["electron", "claude", "gemini", "tokens", "developer-tools"],
  "author": "Dewashish Lambore",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dewashish.tokenmeter",
    "productName": "Tokenmeter",
    "copyright": "© 2026 Dewashish Lambore",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tokenmeter",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "pricing.json",
      "renderer/**/*",
      "src/**/*",
      "assets/**/*",
      "!**/*.map",
      "!**/node_modules/.cache/**"
    ],
    "extraMetadata": {
      "version": "1.0.0"
    }
  }
}
